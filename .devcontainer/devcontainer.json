{
    "name": "Controlo Estagio",
    "image": "mcr.microsoft.com/devcontainers/typescript-node:20-bookworm",
    "features": {
        "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
            "moby": false
        }
    },
    "forwardPorts": [
        5001,
        5173,
        5432
    ],
    "customizations": {
        "vscode": {
            "extensions": [
                "dbaeumer.vscode-eslint",
                "esbenp.prettier-vscode",
                "Prisma.prisma"
            ]
        }
    }
}
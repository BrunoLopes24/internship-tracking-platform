# ============================================
# StageSync — Environment Configuration
# ============================================
# Copy this file to .env and modify as needed.

# --- Server ---
PORT=5001
NODE_ENV=development

# --- Database (PostgreSQL) ---
# Local development (Docker/Podman):
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/internship_db
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/internship_db

# Production (Neon):
# DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/internship_db?sslmode=require
# DIRECT_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/internship_db?sslmode=require

# --- Frontend ---
VITE_API_URL=http://localhost:5001/api

# --- Timezone ---
TZ=Europe/Lisbon

# --- Application Defaults ---
REQUIRED_HOURS=640
DEFAULT_DAILY_HOURS=8
DEFAULT_WORKING_DAYS=1,2,3,4,5

# --- Security ---
RESET_SECRET=change-me-in-production

# --- File Uploads ---
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
